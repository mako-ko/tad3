*/

///////////////////////////////// TODOS OS USES /////////////////////////////////

/**
 * @swagger
 * tags:
 *   name: Tarefas
 *   description: Rotas para gerenciamento de tarefas
 */

// Aplica o middleware de autenticação a todas as rotas de tarefas (aula 505)
router.use(authMiddleware);


///////////////////////////////// TODOS OS GETS /////////////////////////////////

